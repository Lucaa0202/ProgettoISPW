<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.gui.GestioneRichiesteGUI">
    <children>
        <Label layoutX="30.0" layoutY="30.0" text="Gestione Richieste" textFill="#333333">
            <font>
                <Font name="System Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="30.0" layoutY="70.0" text="Accetta o rifiuta i passeggeri per questo viaggio." textFill="#666666">
            <font>
                <Font size="16.0" />
            </font>
        </Label>

        <TableView fx:id="tableRichieste" layoutX="30.0" layoutY="120.0" prefHeight="380.0" prefWidth="740.0">
            <columns>
                <TableColumn fx:id="passeggeroCol" prefWidth="340.0" text="Email Passeggero" />
                <TableColumn fx:id="accettaCol" prefWidth="200.0" text="Accetta" />
                <TableColumn fx:id="rifiutaCol" prefWidth="200.0" text="Rifiuta" />
            </columns>
        </TableView>

        <Button layoutX="30.0" layoutY="530.0" mnemonicParsing="false" onMouseClicked="#tornaIndietro" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #cccccc; -fx-cursor: hand;" text="Indietro">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <!-- NUOVO BOTTONE: INVITA PASSEGGERO -->
        <Button layoutX="600.0" layoutY="530.0" mnemonicParsing="false" onMouseClicked="#apriPopUpInvito" prefHeight="35.0" prefWidth="170.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-cursor: hand;" text="Invita Passeggero">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </children>
</AnchorPane>