<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.effect.InnerShadow?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="542.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.gui.RisultatiRicercaGUI">
    <children>
        <BorderPane prefHeight="542.0" prefWidth="900.0">
            <top>
                <AnchorPane prefHeight="78.0" prefWidth="900.0" BorderPane.alignment="CENTER">
                    <children>
                        <Text layoutX="330.0" layoutY="50.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Cerca un Passaggio">
                            <font><Font name="Segoe UI Black" size="24.0" /></font>
                        </Text>
                        <Button layoutX="40.0" layoutY="25.0" mnemonicParsing="false" onMouseClicked="#tornaIndietro" prefHeight="35.0" prefWidth="80.0" style="-fx-background-radius: 22px; -fx-background-color: #efefef;" text="Indietro">
                            <font><Font name="Segoe UI Semibold" size="14.0" /></font>
                            <effect><DropShadow blurType="GAUSSIAN" height="12.0" offsetY="1.0" radius="5.0" width="10.0"><color><Color opacity="0.5" /></color></DropShadow></effect>
                        </Button>
                    </children>
                </AnchorPane>
            </top>
            <center>
                <AnchorPane prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER">
                    <children>

                        <ComboBox fx:id="tendinaPartenza" layoutX="100.0" layoutY="20.0" prefHeight="40.0" prefWidth="200.0" promptText="Partenza" style="-fx-background-color: #f7f7f7; -fx-background-radius: 22px;">
                            <effect><InnerShadow height="15.0" radius="7.0" width="15.0"><color><Color opacity="0.25" /></color></InnerShadow></effect>
                        </ComboBox>

                        <ComboBox fx:id="tendinaArrivo" layoutX="350.0" layoutY="20.0" prefHeight="40.0" prefWidth="200.0" promptText="Destinazione" style="-fx-background-color: #f7f7f7; -fx-background-radius: 22px;">
                            <effect><InnerShadow height="15.0" radius="7.0" width="15.0"><color><Color opacity="0.25" /></color></InnerShadow></effect>
                        </ComboBox>

                        <Button layoutX="600.0" layoutY="20.0" mnemonicParsing="false" onMouseClicked="#eseguiRicerca" prefHeight="40.0" prefWidth="120.0" style="-fx-background-radius: 22px; -fx-background-color: #efefef;" text="Cerca">
                            <font><Font name="Segoe UI Bold" size="14.0" /></font>
                            <effect><DropShadow blurType="GAUSSIAN" height="12.0" offsetY="1.0" radius="5.0" width="10.0"><color><Color opacity="0.5" /></color></DropShadow></effect>
                        </Button>

                        <TableView fx:id="tabellaViaggi" layoutX="20.0" layoutY="90.0" prefHeight="300.0" prefWidth="860.0" style="-fx-background-color: #f7f7f7; -fx-border-radius: 10px; -fx-background-radius: 10px;">
                            <columns>
                                <TableColumn fx:id="colonnaGuidatore" prefWidth="220.0" text="Guidatore" />
                                <!-- NUOVA COLONNA BOTTONE LEGGI -->
                                <TableColumn fx:id="colonnaRecensioniBtn" prefWidth="65.0" text="Voti" />
                                <TableColumn fx:id="colonnaPartenza" prefWidth="110.0" text="Partenza" />
                                <TableColumn fx:id="colonnaDestinazione" prefWidth="110.0" text="Destinazione" />
                                <TableColumn fx:id="colonnaDataOra" prefWidth="130.0" text="Data e Ora" />
                                <TableColumn fx:id="colonnaPosti" prefWidth="55.0" text="Posti" />
                                <TableColumn fx:id="colonnaPrezzo" prefWidth="65.0" text="Prezzo" />
                                <TableColumn fx:id="colonnaBottone" prefWidth="75.0" text="Azione" />
                            </columns>
                        </TableView>

                        <Text fx:id="messaggio" fill="#ff0027" layoutX="20.0" layoutY="430.0" strokeType="OUTSIDE" strokeWidth="0.0" textAlignment="CENTER" visible="false" wrappingWidth="860.0">
                            <font><Font name="Segoe UI" size="16.0" /></font>
                        </Text>

                    </children>
                </AnchorPane>
            </center>
        </BorderPane>
    </children>
</AnchorPane>