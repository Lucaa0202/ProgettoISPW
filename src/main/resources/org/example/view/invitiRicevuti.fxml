<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="542.0" prefWidth="762.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="view.gui.InvitiRicevutiGUI">
    <children>
        <Label layoutX="40.0" layoutY="30.0" text="Inviti Ricevuti" textFill="#333333">
            <font>
                <Font name="Segoe UI Bold" size="28.0" />
            </font>
        </Label>

        <Label layoutX="40.0" layoutY="70.0" text="Accetta o rifiuta gli inviti diretti inviati dai guidatori." textFill="#666666">
            <font>
                <Font name="Segoe UI" size="16.0" />
            </font>
        </Label>

        <TableView fx:id="tabellaInviti" layoutX="40.0" layoutY="120.0" prefHeight="330.0" prefWidth="680.0" style="-fx-background-color: white; -fx-background-radius: 10px;">
            <columns>
                <TableColumn fx:id="colonnaDettagliViaggio" prefWidth="420.0" text="Dettagli Viaggio" />
                <TableColumn fx:id="colonnaAccetta" prefWidth="120.0" text="Accetta" />
                <TableColumn fx:id="colonnaRifiuta" prefWidth="120.0" text="Rifiuta" />
            </columns>
        </TableView>

        <!-- Mostrato solo quando non ci sono inviti -->
        <Label fx:id="messaggioVuoto" layoutX="40.0" layoutY="260.0" prefWidth="680.0" alignment="CENTER" text="Nessun invito in sospeso al momento." textFill="#999999" visible="false">
            <font>
                <Font name="Segoe UI Italic" size="18.0" />
            </font>
        </Label>

        <Button layoutX="40.0" layoutY="480.0" mnemonicParsing="false" onMouseClicked="#tornaIndietro" prefHeight="35.0" prefWidth="120.0" style="-fx-background-color: #cccccc; -fx-cursor: hand; -fx-background-radius: 20px;" text="Indietro">
            <font>
                <Font name="Segoe UI Bold" size="14.0" />
            </font>
        </Button>
    </children>
</AnchorPane>